# Repo-local Topos config override. Copy to ./topos.config.yaml (gitignored)
# and edit only the keys you want to override. Layering order:
#   defaults (topos/config_defaults.yaml)
#     < ~/.config/topos/config.yaml
#     < ./topos.config.yaml
#     < env vars (TOPOS__SECTION__KEY=...)

